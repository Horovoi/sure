<%# locals: (debt_flow:) %>
<div class="space-y-4">
  <p class="text-sm text-secondary">
    <%= t("reports.debt_flows.description") %>
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- Debt Paydown -->
    <div class="bg-container border border-primary rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <%= icon("trending-down", size: "sm", class: "text-green-600") %>
        <h3 class="text-sm font-medium text-secondary"><%= t("reports.debt_flows.paydown") %></h3>
      </div>
      <div class="text-2xl font-semibold" style="color: rgb(34 197 94);">
        <%= format_money(debt_flow.paydown) %>
      </div>
      <p class="text-xs text-secondary mt-1"><%= t("reports.debt_flows.paydown_description") %></p>
    </div>

    <!-- New Debt -->
    <div class="bg-container border border-primary rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <%= icon("trending-up", size: "sm", class: "text-orange-600") %>
        <h3 class="text-sm font-medium text-secondary"><%= t("reports.debt_flows.new_debt") %></h3>
      </div>
      <div class="text-2xl font-semibold" style="color: rgb(249 115 22);">
        <%= format_money(debt_flow.new_debt) %>
      </div>
      <p class="text-xs text-secondary mt-1"><%= t("reports.debt_flows.new_debt_description") %></p>
    </div>

    <!-- Net Debt Change -->
    <div class="bg-container border border-primary rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <%= icon("arrow-left-right", size: "sm", class: "text-primary") %>
        <h3 class="text-sm font-medium text-secondary"><%= t("reports.debt_flows.net_change") %></h3>
      </div>
      <div class="text-2xl font-semibold <%= debt_flow.debt_change.amount <= 0 ? "text-success" : "text-destructive" %>">
        <%= format_money(debt_flow.debt_change) %>
      </div>
      <p class="text-xs text-secondary mt-1"><%= t("reports.debt_flows.net_change_description") %></p>
    </div>
  </div>

  <% if debt_flow.account_breakdowns.any? %>
    <div class="bg-container-inset rounded-xl p-1">
      <div role="columnheader" class="grid grid-cols-2 items-center uppercase text-xs font-medium text-secondary px-4 py-2">
        <div><%= t("reports.debt_flows.account") %></div>
        <div class="text-right"><%= t("reports.debt_flows.change") %></div>
      </div>
      <div class="bg-container rounded-lg shadow-border-xs">
        <% debt_flow.account_breakdowns.each_with_index do |breakdown, idx| %>
          <div class="grid grid-cols-2 items-center text-secondary text-sm py-3 px-4 lg:px-6">
            <div class="flex items-center gap-2">
              <%= breakdown.account.name %>
            </div>
            <div class="text-right <%= breakdown.change.amount <= 0 ? "text-success" : "text-destructive" %>">
              <%= format_money(breakdown.change) %>
            </div>
          </div>
          <% if idx < debt_flow.account_breakdowns.size - 1 %>
            <%= render "shared/ruler", classes: "mx-3 lg:mx-4" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
