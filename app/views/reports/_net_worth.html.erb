<div class="space-y-6">
  <%# Main Net Worth Stats %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%# Current Net Worth %>
    <div class="p-4 bg-surface-inset rounded-lg">
      <p class="text-sm text-secondary mb-2"><%= t("reports.net_worth.current_net_worth") %></p>
      <p class="text-2xl font-semibold <%= net_worth_metrics[:current_net_worth] >= 0 ? "text-success" : "text-destructive" %>">
        <%= net_worth_metrics[:current_net_worth].format %>
      </p>
    </div>

    <%# Period Change %>
    <div class="p-4 bg-surface-inset rounded-lg">
      <p class="text-sm text-secondary mb-2"><%= t("reports.net_worth.period_change") %></p>
      <% if net_worth_metrics[:trend] %>
        <% trend = net_worth_metrics[:trend] %>
        <p class="text-2xl font-semibold mb-1" style="color: <%= trend.color %>">
          <%= trend.value.format(signify_positive: true) %>
        </p>
        <p class="text-xs" style="color: <%= trend.color %>">
          <%= trend.value >= 0 ? "+" : "" %><%= trend.percent_formatted %>
        </p>
        <% if net_worth_metrics[:attribution] %>
          <% attr = net_worth_metrics[:attribution] %>
          <div class="mt-3 pt-2 border-t border-secondary space-y-1">
            <div class="flex justify-between text-xs text-secondary">
              <span><%= t("reports.net_worth.from_cash_flow") %></span>
              <span class="<%= attr[:cash_flow] >= 0 ? "text-success" : "text-destructive" %>">
                <%= attr[:cash_flow].format(signify_positive: true) %>
              </span>
            </div>
            <% if attr[:debt_change].amount != 0 %>
              <div class="flex justify-between text-xs text-secondary">
                <span><%= t("reports.net_worth.from_debt_changes") %></span>
                <span class="<%= attr[:debt_change].amount <= 0 ? "text-success" : "text-destructive" %>">
                  <%= attr[:debt_change].format(signify_positive: true) %>
                </span>
              </div>
            <% end %>
            <% if attr[:other].amount != 0 %>
              <div class="flex justify-between text-xs text-secondary">
                <span class="inline-flex items-center gap-1">
                  <%= t("reports.net_worth.from_other") %>
                  <%= render DS::Tooltip.new(text: t("reports.net_worth.other_tooltip")) %>
                </span>
                <span class="<%= attr[:other] >= 0 ? "text-success" : "text-destructive" %>">
                  <%= attr[:other].format(signify_positive: true) %>
                </span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-2xl font-semibold mb-1 text-tertiary">--</p>
      <% end %>
    </div>

    <%# Assets vs Liabilities %>
    <div class="p-4 bg-surface-inset rounded-lg">
      <p class="text-sm text-secondary mb-2"><%= t("reports.net_worth.assets_vs_liabilities") %></p>
      <div class="flex items-baseline gap-2">
        <span class="text-lg font-semibold text-success"><%= net_worth_metrics[:total_assets].format %></span>
        <span class="text-xs text-tertiary">-</span>
        <span class="text-lg font-semibold text-destructive"><%= net_worth_metrics[:total_liabilities].format %></span>
      </div>
    </div>
  </div>

  <%# Waterfall Chart %>
  <% if net_worth_metrics[:asset_groups].any? || net_worth_metrics[:liability_groups].any? %>
    <%
      assets_json = net_worth_metrics[:asset_groups].map { |g| { name: g[:name], value: g[:total].amount.to_f } }.to_json
      liabilities_json = net_worth_metrics[:liability_groups].map { |g| { name: g[:name], value: g[:total].amount.to_f } }.to_json
      net_worth_val = net_worth_metrics[:current_net_worth].amount.to_f
      currency_symbol = Money::Currency.new(Current.family.currency).symbol
    %>
    <div class="relative"
         data-controller="reports-waterfall-chart"
         data-reports-waterfall-chart-assets-value="<%= assets_json %>"
         data-reports-waterfall-chart-liabilities-value="<%= liabilities_json %>"
         data-reports-waterfall-chart-net-worth-value="<%= net_worth_val %>"
         data-reports-waterfall-chart-currency-value="<%= currency_symbol %>"
         data-reports-waterfall-chart-net-worth-label-value="<%= t("reports.net_worth.net_worth_total") %>">
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-container-inset rounded-xl p-4">
        <p class="text-sm text-secondary text-center"><%= t("reports.net_worth.no_assets") %></p>
      </div>
      <div class="bg-container-inset rounded-xl p-4">
        <p class="text-sm text-tertiary text-center"><%= t("reports.net_worth.no_liabilities") %></p>
      </div>
    </div>
  <% end %>
</div>
