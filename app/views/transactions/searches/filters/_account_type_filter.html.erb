<%# locals: (form:) %>

<div class="p-2 space-y-3">
  <div class="flex items-center gap-3" data-filter-name="income">
    <%= form.check_box :types,
                           {
                             multiple: true,
                             checked: @q[:types]&.include?("income"),
                             class: "checkbox checkbox--light"
                           },
                           "income",
                           nil %>
    <%= form.label :types, t(".income"), value: "income", class: "text-sm text-primary" %>
  </div>
  <div class="flex items-center gap-3" data-filter-name="expense">
    <%= form.check_box :types,
                           {
                             multiple: true,
                             checked: @q[:types]&.include?("expense"),
                             class: "checkbox checkbox--light"
                           },
                           "expense",
                           nil %>
    <%= form.label :types, t(".expense"), value: "expense", class: "text-sm text-primary" %>
  </div>
  <div class="flex items-center gap-3" data-filter-name="transfer">
    <%= form.check_box :types,
                           {
                             multiple: true,
                             checked: @q[:types]&.include?("transfer"),
                             class: "checkbox checkbox--light"
                           },
                           "transfer",
                           nil %>
    <%= form.label :types, t(".transfer"), value: "transfer", class: "text-sm text-primary" %>
  </div>
  <div class="flex items-center gap-3" data-filter-name="balance_update">
    <%= form.check_box :types,
                           {
                             multiple: true,
                             checked: @q[:types]&.include?("balance_update"),
                             class: "checkbox checkbox--light"
                           },
                           "balance_update",
                           nil %>
    <%= form.label :types, t(".balance_update"), value: "balance_update", class: "text-sm text-primary" %>
  </div>
  <div class="flex items-center gap-3" data-filter-name="trade">
    <%= form.check_box :types,
                           {
                             multiple: true,
                             checked: @q[:types]&.include?("trade"),
                             class: "checkbox checkbox--light"
                           },
                           "trade",
                           nil %>
    <%= form.label :types, t(".trade"), value: "trade", class: "text-sm text-primary" %>
  </div>
</div>
