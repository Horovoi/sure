<%# locals: (import:) %>

<div class="h-full flex flex-col justify-center items-center">
  <div class="space-y-6 max-w-lg w-full">
    <% if import.pending? && import.rows_count > 0 %>
      <div class="mx-auto bg-success/10 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "check", class: "text-success" %>
      </div>

      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl">Ready for Review</h1>
        <p class="text-sm text-secondary">We extracted <%= import.rows_count %> transactions from your statement. Review them, choose an account, and publish when ready.</p>
      </div>

      <div class="bg-container border border-primary rounded-xl p-4 space-y-4">
        <div class="space-y-2">
          <h2 class="font-medium text-primary">Document type</h2>
          <p class="text-sm text-secondary px-3 py-2 bg-gray-500/5 rounded-lg"><%= import.document_type&.humanize || "Unknown" %></p>
        </div>

        <div class="space-y-2">
          <h2 class="font-medium text-primary">Transactions extracted</h2>
          <p class="text-sm text-secondary px-3 py-2 bg-gray-500/5 rounded-lg"><%= pluralize(import.rows_count, "transaction") %></p>
        </div>

        <div class="space-y-2">
          <h2 class="font-medium text-primary">Import to account</h2>
          <%= form_with model: import, url: import_path(import), method: :patch, class: "space-y-2" do |form| %>
            <% accounts = import.family.accounts.manual.alphabetically %>
            <% if accounts.any? %>
              <%= form.select :account_id, options_for_select(accounts.map { |account| [account.name, account.id] }, import.account_id), { include_blank: "Select an account..." }, class: "form-field__input" %>
              <% if import.account.nil? %>
                <p class="text-xs text-secondary">Choose which account these transactions should be published into.</p>
              <% end %>
              <%= form.submit "Save account", class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
            <% else %>
              <p class="text-sm text-secondary px-3 py-2 bg-yellow-500/10 rounded-lg">No manual accounts available. Create one first to publish this import.</p>
              <%= render DS::Link.new(text: "Create account", href: new_depository_path(return_to: import_path(import)), variant: "primary", full_width: true, frame: :modal) %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="space-y-2 flex flex-col">
        <% if import.publishable? %>
          <%= button_to "Publish #{pluralize(import.rows_count, 'transaction')}", publish_import_path(import), method: :post, class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
          <%= render DS::Link.new(text: "Review transactions", href: import_clean_path(import), variant: "secondary", full_width: true) %>
        <% elsif import.account.present? %>
          <%= render DS::Link.new(text: "Review transactions", href: import_clean_path(import), variant: "primary", full_width: true) %>
        <% else %>
          <p class="text-center text-sm text-secondary">Select an account above to continue.</p>
        <% end %>
        <%= render DS::Link.new(text: "Back to imports", href: imports_path, variant: "secondary", full_width: true) %>
      </div>
    <% elsif import.importing? || import.pending? %>
      <div class="mx-auto bg-gray-500/5 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "loader", class: "animate-pulse" %>
      </div>

      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl">Processing document</h1>
        <p class="text-sm text-secondary">AI is classifying the PDF and extracting any transactions it can find.</p>
      </div>

      <div class="space-y-2 flex flex-col">
        <%= render DS::Link.new(text: "Refresh status", href: import_path(import), variant: "primary", full_width: true) %>
        <%= render DS::Link.new(text: "Back to dashboard", href: root_path, variant: "secondary", full_width: true) %>
      </div>
    <% elsif import.failed? %>
      <div class="mx-auto bg-destructive/10 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "x", class: "text-destructive" %>
      </div>

      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl">Processing failed</h1>
        <p class="text-sm text-secondary">The PDF could not be processed.</p>
        <% if import.error.present? %>
          <p class="text-sm text-destructive"><%= import.error %></p>
        <% end %>
      </div>

      <div class="space-y-2 flex flex-col">
        <%= render DS::Link.new(text: "Try another file", href: new_import_path, variant: "primary", full_width: true) %>
        <%= button_to "Delete import", import_path(import), method: :delete, class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-primary bg-gray-200 hover:bg-gray-300" %>
      </div>
    <% elsif import.complete? && import.ai_processed? %>
      <div class="mx-auto bg-success/10 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "check", class: "text-success" %>
      </div>

      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl">Document indexed</h1>
        <p class="text-sm text-secondary">The file was analyzed and added to the family document vault.</p>
      </div>

      <div class="bg-container border border-primary rounded-xl p-4 space-y-4">
        <div class="space-y-2">
          <h2 class="font-medium text-primary">Document type</h2>
          <p class="text-sm text-secondary px-3 py-2 bg-gray-500/5 rounded-lg"><%= import.document_type&.humanize || "Unknown" %></p>
        </div>

        <div class="space-y-2">
          <h2 class="font-medium text-primary">Summary</h2>
          <p class="text-sm text-secondary px-3 py-2 bg-gray-500/5 rounded-lg whitespace-pre-wrap"><%= import.ai_summary %></p>
        </div>
      </div>

      <div class="space-y-2 flex flex-col">
        <%= render DS::Link.new(text: "Back to imports", href: imports_path, variant: "primary", full_width: true) %>
        <%= button_to "Delete import", import_path(import), method: :delete, class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-primary bg-gray-200 hover:bg-gray-300" %>
      </div>
    <% else %>
      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl">Unknown import state</h1>
        <p class="text-sm text-secondary">Refresh the page or return to Imports.</p>
      </div>

      <div class="space-y-2 flex flex-col">
        <%= render DS::Link.new(text: "Back to imports", href: imports_path, variant: "primary", full_width: true) %>
      </div>
    <% end %>
  </div>
</div>
